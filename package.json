{
  "name": "website-next-boilerplate",
  "version": "0.0.0",
  "description": "A boilerplate for a website using Payload CMS and Next.js",
  "repository": "git@github.com:innovixx/website-next-boilerplate.git",
  "author": "Innovixx <support@innovixx.co.uk>",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm watch:generate-types:styles\" \"next dev --webpack\" --hide=0",
    "build": "next build",
    "serve": "next start",
    "codegen": "cross-env TS_NODE_PROJECT=tsconfig.codegen.json graphql-codegen --config codegen.ts",
    "generate-types:styles": "typed-scss-modules src --outputFolder src/types/styles",
    "watch:generate-types:styles": "pnpm generate-types:styles --watch --logLevel=silent",
    "lint": "eslint ./src/**/*.{js,jsx,ts,tsx,graphql}",
    "lint-staged": "lint-staged --verbose",
    "stylelint": "stylelint \"src/**/*.scss\"",
    "prepare": "if [ -d node_modules/husky ]; then husky; fi"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@apollo/react-hooks": "^4.0.0",
    "@faceless-ui/collapsibles": "2.0.0-beta.1",
    "@faceless-ui/css-grid": "^1.2.1",
    "@faceless-ui/modal": "2.0.0",
    "@faceless-ui/scroll-info": "^2.0.0",
    "@faceless-ui/slider": "2.0.0-beta.1",
    "@faceless-ui/window-info": "^3.0.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@innovixx/react-form-fields": "^1.0.3",
    "@lexical/list": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@payloadcms/live-preview-react": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "axios": "^1.16.1",
    "color": "^5.0.3",
    "dayjs": "^1.11.20",
    "deepmerge": "^4.3.1",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.0",
    "graphql-request": "^7.4.0",
    "lexical": "^0.44.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "7.75.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@graphql-codegen/typescript-react-apollo": "^4.4.2",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@innovixx/eslint-config": "^3.0.12",
    "@innovixx/stylelint-config": "^1.0.8",
    "@types/color": "^4.2.1",
    "@types/escape-html": "^1.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "cross-env": "^10.1.0",
    "eslint": "9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "nodemon": "^3.1.14",
    "stylelint": "^17.11.1",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-scss": "^7.1.1",
    "ts-node": "^10.9.2",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "**/*.graphql": "eslint",
    "**/*.scss": "stylelint",
    "**/*.{js,ts,jsx,tsx}": [
      "eslint --quiet",
      "bash -c tsc"
    ]
  }
}